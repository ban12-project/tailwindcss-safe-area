{
  "name": "@ban12/tailwindcss-safe-area",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "repository": "https://github.com/ban12-project/tailwindcss-safe-area",
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "pnpm test:matrix",
    "test:matrix": "pnpm test:v3 && pnpm test:v4",
    "test:v3": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --no-watchman --config ./jest.v3.config.cjs",
    "test:v4": "pnpm build && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --no-watchman --config ./jest.v4.config.cjs",
    "swcify:cjs": "swc src -d dist --strip-leading-paths",
    "swcify:esm": "swc src -d dist --strip-leading-paths -C module.type=es6 --out-file-extension mjs",
    "swcify": "pnpm swcify:cjs && pnpm swcify:esm",
    "build": "pnpm swcify",
    "dev": "pnpm swcify -- --watch",
    "postbuild": "tsc --emitDeclarationOnly",
    "prepublishOnly": "pnpm build",
    "release-channel": "node ./scripts/release-channel.js",
    "release-notes": "node ./scripts/release-notes.js"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "tailwindcss": ">=3.2.0 <5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@swc/cli": "^0.3.10",
    "@swc/core": "^1.4.11",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.12",
    "expect": "^29.7.0",
    "jest": "^29.7.0",
    "jest-diff": "^29.7.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.0.0",
    "tailwindcss-v3": "npm:tailwindcss@^3.4.0",
    "tailwindcss-v4": "npm:tailwindcss@^4.0.0",
    "typescript": "^5.4.3"
  }
}
